{
  "name": "open-lyrics",
  "displayName": "Open Lyrics (LRCLIB)",
  "version": "1.0.0",
  "description": "Fetches synced and plain lyrics from LRCLIB",
  "author": "SpotiFLAC Extensions",
  "permissions": {
    "network": ["lrclib.net"],
    "storage": true
  },
  "type": [
    "lyrics_provider",
    "metadata_provider",
    "download_provider"
  ],
  "settings": [
    {
      "key": "preferSynced",
      "label": "Prefer Synced Lyrics",
      "type": "boolean",
      "default": true
    },
    {
      "key": "cacheResults",
      "label": "Cache Lyrics",
      "type": "boolean",
      "default": true
    }
  ]
}
